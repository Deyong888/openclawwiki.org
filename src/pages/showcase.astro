---

<Layout metadata={metadata}>
  <Hero
    tagline="Showcase"
    title="OpenClaw Use Cases"
    subtitle="Discover how the community is using OpenClaw to automate workflows, build businesses, and enhance productivity."
  />

  <WidgetWrapper containerClass="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid gap-16">
      {categories.map((category) => (
        <section id={category.id} class="scroll-mt-20">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-lg bg-blue-100 dark:bg-blue-900 flex items-center justify-center">
              <iconify-icon icon={category.icon} class="text-xl text-blue-600 dark:text-blue-400"></iconify-icon>
            </div>
            <div>
              <h2 class="text-2xl font-bold text-gray-900 dark:text-white">{category.name}</h2>
              <p class="text-sm text-gray-500 dark:text-gray-400">{category.nameCN} · {category.description}</p>
            </div>
          </div>
          
          <p class="text-gray-600 dark:text-gray-300 mb-6">{category.descriptionCN}</p>
          
          <div class="grid gap-6 md:grid-cols-2">
            {category.usecases.map((usecase) => (
              <a
                href={`/docs/usecases/${usecase.file.replace('.md', '')}`}
                class="block p-6 bg-white dark:bg-slate-800 rounded-xl shadow-sm hover:shadow-md transition-all border border-gray-200 dark:border-gray-700 group"
              >
                <div class="flex items-start justify-between">
                  <h3 class="text-lg font-semibold text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                    {usecase.title}
                  </h3>
                  <iconify-icon icon="tabler:arrow-right" class="text-gray-400 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors"></iconify-icon>
                </div>
                <p class="mt-2 text-sm text-gray-600 dark:text-gray-300 leading-relaxed">
                  {usecase.summary}
                </p>
                <p class="mt-2 text-sm text-gray-500 dark:text-gray-400 leading-relaxed">
                  {usecase.summaryCN}
                </p>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </WidgetWrapper>

  <section class="py-12 bg-blue-50 dark:bg-slate-800 mt-12">
    <div class="max-w-4xl mx-auto text-center px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl mb-6">
        Built something cool?
      </h2>
      <p class="text-xl text-gray-600 dark:text-gray-300 mb-8">
        Share your OpenClaw agent with the community.
      </p>
      <a
        href="https://github.com/openclaw/awesome-openclaw-usecases"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary"
      >
        Add Your Use Case
      </a>
    </div>
  </section>
</Layout>
